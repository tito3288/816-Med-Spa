<button type="button" aria-label="Take our quiz" class="quiz-tab hidden min-[900px]:block">
  Take Our Quiz
</button>

<style>
  .quiz-tab {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 30;
    background: rgba(50, 43, 33, 0.35);
    border: 1px solid rgba(246, 240, 227, 0.45);
    color: var(--color-parchment);
    padding: 24px 10px;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    font-family: var(--font-serif-italic);
    font-size: 20px;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .quiz-tab:hover {
    background: rgba(50, 43, 33, 0.6);
  }
</style>
