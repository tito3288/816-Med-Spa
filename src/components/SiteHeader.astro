---
const navLinks = [
  { href: "#conditions", label: "Services", hasDropdown: true },
  { href: "#payment-plans", label: "Payment Plans" },
  { href: "#about", label: "About Us", hasDropdown: true },
  { href: "#contact", label: "Contact Us" },
];
---

<header class="sticky top-0 z-50 border-b border-sage/20 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Mobile / tablet: single row -->
    <div class="flex items-center justify-between py-4 md:py-5 lg:hidden">
      <a href="/" class="shrink-0" aria-label="816 Med Spa home">
        <img src="/logo.png" alt="816 Med Spa" class="h-16 w-auto sm:h-20" />
      </a>
      <div class="flex items-center gap-3">
        <a
          href="#contact"
          class="hidden rounded-lg bg-sage px-4 py-2.5 text-sm font-medium text-white transition hover:bg-sage/90 sm:inline-block"
        >
          Request Appointment
        </a>
        <button
          type="button"
          class="p-2 text-gray-900 transition hover:text-sage"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          data-mobile-menu-button
        >
          <svg
            class="h-6 w-6"
            data-icon="open"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            class="hidden h-6 w-6"
            data-icon="close"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 6l12 12M6 18L18 6"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Desktop: single row -->
    <div class="hidden lg:grid grid-cols-[auto_1fr_auto] items-center gap-8 py-4 xl:gap-10">
      <a href="/" class="shrink-0" aria-label="816 Med Spa home">
        <img
          src="/logo.png"
          alt="816 Med Spa"
          class="h-20 w-auto xl:h-24"
        />
      </a>
      <nav
        class="flex flex-wrap items-center justify-end gap-x-6 gap-y-2 xl:gap-x-10"
        aria-label="Primary"
      >
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="inline-flex items-center gap-1.5 font-body text-xs font-medium tracking-[0.14em] text-gray-900 uppercase transition hover:text-sage focus-visible:text-sage"
          >
            {link.label}
            {link.hasDropdown && (
              <svg
                class="h-3 w-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 9l6 6 6-6"></path>
              </svg>
            )}
          </a>
        ))}
      </nav>
      <a
        href="#contact"
        class="rounded-lg bg-sage px-7 py-2.5 text-sm font-medium text-white transition hover:bg-sage/90"
      >
        Request Appointment
      </a>
    </div>

    <div id="mobile-menu" class="hidden pb-4 lg:hidden" data-mobile-menu>
      <nav class="flex flex-col gap-1 border-t border-sage/20 pt-4" aria-label="Mobile">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="inline-flex items-center gap-2 px-2 py-3 text-base font-medium transition hover:text-sage focus-visible:text-sage"
          >
            {link.label}
            {link.hasDropdown && (
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 9l6 6 6-6"></path>
              </svg>
            )}
          </a>
        ))}
        <a
          href="#contact"
          class="mt-3 rounded-lg bg-sage px-6 py-3 text-center font-medium text-white hover:bg-sage/90 transition"
        >
          Request Appointment
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>("[data-mobile-menu-button]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  if (button && menu) {
    const openIcon = button.querySelector<SVGElement>('[data-icon="open"]');
    const closeIcon = button.querySelector<SVGElement>('[data-icon="close"]');

    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      button.setAttribute("aria-expanded", String(open));
      button.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      openIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
    };

    button.addEventListener("click", () => {
      setOpen(menu.classList.contains("hidden"));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !menu.classList.contains("hidden")) {
        setOpen(false);
        button.focus();
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });
  }
</script>
