---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "#about", label: "About", caret: true },
  { href: "#services", label: "Services", caret: true },
  { href: "#conditions", label: "Conditions", caret: true },
  { href: "#treatments", label: "Treatments", caret: true },
  { href: "#gallery", label: "Gallery" },
  { href: "#contact", label: "Contact" },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent text-parchment transition-colors duration-300"
  data-site-header
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Mobile / tablet: single row -->
    <div class="flex items-center justify-between py-4 md:py-5 min-[900px]:hidden">
      <a href="/" class="shrink-0" aria-label="816 Med Spa home">
        <img src="/logo.png" alt="816 Med Spa" class="h-16 w-auto sm:h-20" />
      </a>
      <div class="flex items-center gap-3">
        <a
          href="#"
          class="hidden border border-parchment/70 bg-transparent px-4 py-2.5 font-sans-wide text-[11px] font-medium tracking-[0.35em] text-parchment uppercase transition hover:bg-parchment hover:text-ink sm:inline-block"
          data-header-cta
        >
          Book Now
        </a>
        <button
          type="button"
          class="p-2 text-current transition hover:text-sage"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          data-mobile-menu-button
        >
          <svg
            class="h-6 w-6"
            data-icon="open"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            class="hidden h-6 w-6"
            data-icon="close"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 6l12 12M6 18L18 6"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Desktop: centered logo + nav row -->
    <div
      class="hidden py-6 transition-[padding] duration-300 min-[900px]:block"
      data-desktop-header-inner
    >
      <div class="grid grid-cols-[1fr_auto_1fr] items-center">
        <div aria-hidden="true"></div>
        <a
          href="/"
          class="flex flex-col items-center justify-self-center"
          aria-label="816 Med Spa home"
        >
          <img
            src="/logo.png"
            alt="816 Med Spa"
            class="h-[110px] w-auto drop-shadow-[0_2px_14px_rgba(0,0,0,0.35)] transition-all duration-300"
            data-header-logo
          />
          <span
            class="mt-2 overflow-hidden font-sans-wide text-[10px] tracking-[0.55em] text-parchment uppercase opacity-100 transition-all duration-300"
            data-header-subtitle
          >
            Med Spa &middot; Kansas City
          </span>
        </a>
        <div class="flex items-center justify-end gap-[18px] justify-self-end">
          <a
            href="#"
            class="border border-parchment/70 bg-transparent px-6 py-[14px] font-sans-wide text-[11px] font-medium tracking-[0.35em] text-parchment uppercase transition hover:bg-parchment hover:text-ink"
            data-header-cta
          >
            Book Now
          </a>
          <button
            type="button"
            aria-label="Search"
            class="grid h-[22px] w-[22px] place-items-center rounded-full border border-parchment text-[12px] leading-none text-parchment transition hover:bg-parchment hover:text-ink"
          >
            ⌕
          </button>
        </div>
      </div>
      <nav
        class="mt-6 flex flex-wrap items-center justify-center gap-x-12 gap-y-2 transition-[margin] duration-300"
        aria-label="Primary"
        data-header-nav
      >
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="inline-flex items-center font-sans-wide text-[11px] font-medium tracking-[0.35em] text-current uppercase transition hover:text-sage focus-visible:text-sage"
            data-header-nav-link
          >
            {link.label}
            {link.caret && (
              <span aria-hidden="true" class="ml-1 text-[9px] opacity-80">▾</span>
            )}
          </a>
        ))}
      </nav>
    </div>

    <div id="mobile-menu" class="hidden pb-4 min-[900px]:hidden" data-mobile-menu>
      <nav class="flex flex-col gap-1 border-t border-current/20 pt-4" aria-label="Mobile">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-2 py-3 text-base font-medium text-current transition hover:text-sage focus-visible:text-sage"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#"
          class="mt-3 border border-parchment/70 bg-transparent px-6 py-3 text-center font-medium text-parchment transition hover:bg-parchment hover:text-ink"
          data-header-cta
        >
          Book Now
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  const headerCtas = document.querySelectorAll<HTMLElement>("[data-header-cta]");
  const headerNavLinks = document.querySelectorAll<HTMLElement>("[data-header-nav-link]");
  const headerLogo = document.querySelector<HTMLElement>("[data-header-logo]");
  const headerSubtitle = document.querySelector<HTMLElement>("[data-header-subtitle]");
  const desktopHeaderInner = document.querySelector<HTMLElement>("[data-desktop-header-inner]");
  const headerNav = document.querySelector<HTMLElement>("[data-header-nav]");
  const button = document.querySelector<HTMLButtonElement>("[data-mobile-menu-button]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  const setHeaderAtTop = () => {
    if (!header) return;

    const menuOpen = menu ? !menu.classList.contains("hidden") : false;
    const atTop = window.scrollY < 12 && !menuOpen;

    header.classList.toggle("border-transparent", atTop);
    header.classList.toggle("bg-transparent", atTop);
    header.classList.toggle("text-parchment", atTop);
    header.classList.toggle("border-sage/20", !atTop);
    header.classList.toggle("bg-white", !atTop);
    header.classList.toggle("text-gray-900", !atTop);
    header.classList.toggle("shadow-sm", !atTop);

    desktopHeaderInner?.classList.toggle("py-6", atTop);
    desktopHeaderInner?.classList.toggle("py-4", !atTop);
    headerLogo?.classList.toggle("h-[110px]", atTop);
    headerLogo?.classList.toggle("h-14", !atTop);
    headerLogo?.classList.toggle("xl:h-16", !atTop);
    headerNav?.classList.toggle("mt-6", atTop);
    headerNav?.classList.toggle("mt-3", !atTop);

    headerSubtitle?.classList.toggle("opacity-100", atTop);
    headerSubtitle?.classList.toggle("mt-2", atTop);
    headerSubtitle?.classList.toggle("opacity-0", !atTop);
    headerSubtitle?.classList.toggle("mt-0", !atTop);
    headerSubtitle?.classList.toggle("h-0", !atTop);

    headerNavLinks.forEach((link) => {
      link.classList.toggle("text-[11px]", atTop);
      link.classList.toggle("tracking-[0.35em]", atTop);
      link.classList.toggle("text-[10px]", !atTop);
      link.classList.toggle("tracking-[0.28em]", !atTop);
    });

    headerCtas.forEach((cta) => {
      cta.classList.toggle("border-parchment/70", atTop);
      cta.classList.toggle("bg-transparent", atTop);
      cta.classList.toggle("text-parchment", atTop);
      cta.classList.toggle("hover:bg-parchment", atTop);
      cta.classList.toggle("hover:text-ink", atTop);
      cta.classList.toggle("border-sage", !atTop);
      cta.classList.toggle("bg-sage", !atTop);
      cta.classList.toggle("text-white", !atTop);
      cta.classList.toggle("hover:bg-sage/90", !atTop);
    });
  };

  setHeaderAtTop();
  window.addEventListener("scroll", setHeaderAtTop, { passive: true });

  if (button && menu) {
    const openIcon = button.querySelector<SVGElement>('[data-icon="open"]');
    const closeIcon = button.querySelector<SVGElement>('[data-icon="close"]');

    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      button.setAttribute("aria-expanded", String(open));
      button.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      openIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
      setHeaderAtTop();
    };

    button.addEventListener("click", () => {
      setOpen(menu.classList.contains("hidden"));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !menu.classList.contains("hidden")) {
        setOpen(false);
        button.focus();
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });
  }
</script>
