---
const navLinks = [
  { href: "#services", label: "Services" },
  { href: "#conditions", label: "Conditions" },
  { href: "#about", label: "About" },
  { href: "#gallery", label: "Gallery" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-sage/20 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Mobile / tablet: single row -->
    <div class="flex items-center justify-between py-4 md:py-5 lg:hidden">
      <a href="/" class="shrink-0" aria-label="816 Med Spa home">
        <img src="/logo.png" alt="816 Med Spa" class="h-14 w-auto sm:h-16" />
      </a>
      <div class="flex items-center gap-3">
        <a
          href="#book"
          class="hidden bg-sage px-4 py-2.5 text-sm font-medium text-white transition hover:bg-sage/90 sm:inline-block"
        >
          Book Appointment
        </a>
        <button
          type="button"
          class="p-2 text-gray-900 transition hover:text-sage"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          data-mobile-menu-button
        >
          <svg
            class="h-6 w-6"
            data-icon="open"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            class="hidden h-6 w-6"
            data-icon="close"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 6l12 12M6 18L18 6"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Desktop: logo row + nav row (reference layout) -->
    <div class="hidden lg:block">
      <div
        class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 pt-6 pb-3"
      >
        <div aria-hidden="true"></div>
        <a href="/" class="justify-self-center" aria-label="816 Med Spa home">
          <img
            src="/logo.png"
            alt="816 Med Spa"
            class="h-auto w-auto max-h-20 xl:max-h-[5.25rem]"
          />
        </a>
        <div class="flex justify-end">
          <a
            href="#book"
            class="bg-sage px-7 py-2.5 text-sm font-medium text-white transition hover:bg-sage/90"
          >
            Book Appointment
          </a>
        </div>
      </div>
      <nav
        class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 pb-6 pt-2 xl:gap-x-10"
        aria-label="Primary"
      >
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-body text-xs font-medium tracking-[0.14em] text-gray-900 uppercase transition hover:text-sage focus-visible:text-sage"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div id="mobile-menu" class="hidden pb-4 lg:hidden" data-mobile-menu>
      <nav class="flex flex-col gap-1 border-t border-sage/20 pt-4" aria-label="Mobile">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-2 py-3 text-base font-medium transition hover:text-sage focus-visible:text-sage"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#book"
          class="mt-3 bg-sage px-6 py-3 text-center font-medium text-white hover:bg-sage/90 transition"
        >
          Book Appointment
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>("[data-mobile-menu-button]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  if (button && menu) {
    const openIcon = button.querySelector<SVGElement>('[data-icon="open"]');
    const closeIcon = button.querySelector<SVGElement>('[data-icon="close"]');

    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      button.setAttribute("aria-expanded", String(open));
      button.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      openIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
    };

    button.addEventListener("click", () => {
      setOpen(menu.classList.contains("hidden"));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !menu.classList.contains("hidden")) {
        setOpen(false);
        button.focus();
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });
  }
</script>
