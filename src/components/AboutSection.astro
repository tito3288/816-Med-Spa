---
import SectionBadge from "./SectionBadge.astro";

const features = [
  {
    title: "Cutting-Edge Technology",
    description: "Modern treatment options selected for safe, effective, confidence-building care",
  },
  {
    title: "Artful Aesthetics",
    description: "An expert touch focused on refined results that enhance your natural beauty",
  },
  {
    title: "Tailored Treatment Options",
    description: "Health and cosmetic services shaped around your goals, lifestyle, and comfort",
  },
];
---

<section id="about" class="py-20 lg:py-32 bg-gradient-to-br from-lavender/30 to-warmGray">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <SectionBadge label="World-Class Expertise" class="mb-6" />
          <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl mb-6 leading-tight" data-reveal>
            Beauty Inside and Out
          </h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed" data-reveal style="--reveal-delay: 120ms">
            Experience a holistic approach to wellness with specialized programs designed to help
            you target your ideal weight, restore balance, and perfect your beauty inside and out.
          </p>
          <p class="text-lg text-gray-700 mb-8 leading-relaxed" data-reveal style="--reveal-delay: 180ms">
            At 816 Aesthetic Med Spa, cutting-edge technology meets artful aesthetics in a calm,
            modern setting. Our rejuvenating services are thoughtfully tailored so your cosmetic
            aspirations can become a stunning reality.
          </p>
          <ul class="space-y-4">
            {features.map((feature, i) => (
              <li class="flex items-start gap-4" data-reveal style={`--reveal-delay: ${240 + i * 80}ms`}>
                <div class="w-12 h-12 bg-sage/20 flex items-center justify-center flex-shrink-0">
                  <svg
                    class="w-6 h-6 text-sage"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold mb-1">{feature.title}</h3>
                  <p class="text-gray-600 text-sm">{feature.description}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="order-1 lg:order-2" data-reveal="fade-left" style="--reveal-delay: 160ms">
          <div class="relative mx-auto max-w-[82%] sm:max-w-md lg:max-w-none">
            <div class="absolute top-3 left-3 h-full w-full bg-sage sm:top-4 sm:left-4" aria-hidden="true"></div>
            <div class="relative aspect-[4/5] bg-gray-200 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=800"
              alt="816 Med Spa team welcoming a client in the treatment room"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="1000"
            />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
