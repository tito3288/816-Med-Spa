---
import SectionBadge from "./SectionBadge.astro";

const features = [
  {
    title: "Expert Medical Team",
    description: "Board-certified professionals with years of specialized experience",
  },
  {
    title: "Advanced Technology",
    description: "State-of-the-art equipment for safe, effective treatments",
  },
  {
    title: "Personalized Plans",
    description: "Custom treatment strategies tailored to your unique goals",
  },
];
---

<section id="about" class="py-20 lg:py-32 bg-gradient-to-br from-lavender/30 to-warmGray">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <SectionBadge label="Our Approach" class="mb-6" />
          <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl mb-6 leading-tight">
            Care That's As Unique As You Are
          </h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            At 816 Med Spa, we believe exceptional care begins with truly listening. Our team
            combines cutting-edge treatments with genuine compassion to help you achieve your
            aesthetic and wellness goals.
          </p>
          <p class="text-lg text-gray-700 mb-8 leading-relaxed">
            Whether you're here for glowing skin, body contouring, or a moment to focus on
            yourself, we combine advanced medical aesthetics with a personal touch in an
            environment designed to make you feel at home.
          </p>
          <ul class="space-y-4">
            {features.map((feature) => (
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-sage/20 flex items-center justify-center flex-shrink-0">
                  <svg
                    class="w-6 h-6 text-sage"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold mb-1">{feature.title}</h3>
                  <p class="text-gray-600 text-sm">{feature.description}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="order-1 lg:order-2">
          <div class="aspect-[4/5] bg-gray-200 rounded-lg overflow-hidden shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=800"
              alt="816 Med Spa team welcoming a client in the treatment room"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="1000"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
