---
---

<section class="relative isolate min-h-screen overflow-hidden bg-espresso text-cream">
  <img
    src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=1800"
    alt="Relaxed client receiving a facial treatment at a med spa"
    class="absolute inset-0 -z-20 size-full object-cover"
    fetchpriority="high"
    decoding="async"
    width="1800"
    height="1200"
  />
  <div class="absolute inset-0 -z-10 bg-espresso/55"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-espresso/45 via-espresso/15 to-espresso/55"></div>

  <div class="container mx-auto flex min-h-screen items-center justify-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p
        class="mb-6 text-xs font-medium tracking-[0.35em] text-cream/85 uppercase"
        data-reveal
      >
        Med Spa in Kansas City, Missouri
      </p>
      <h1
        class="font-display text-5xl leading-[0.95] text-cream italic sm:text-6xl md:text-7xl lg:text-8xl"
        data-reveal
        style="--reveal-delay: 120ms"
      >
        Meet Your Best Self
      </h1>
      <p
        class="mx-auto mt-7 max-w-2xl text-base leading-relaxed text-cream/85 sm:text-lg"
        data-reveal
        style="--reveal-delay: 220ms"
      >
        Restorative medical aesthetics and wellness treatments tailored to help you renew your glow,
        elevate your confidence, and feel at home in your skin.
      </p>
      <div
        class="mt-10 flex flex-col justify-center gap-4 sm:flex-row"
        data-reveal
        style="--reveal-delay: 320ms"
      >
        <a
          href="#contact"
          class="border border-cream/70 px-8 py-3.5 text-xs font-medium tracking-[0.22em] text-cream uppercase transition hover:bg-cream hover:text-espresso"
        >
          Schedule Now
        </a>
        <a
          href="#contact"
          class="border border-cream/70 px-8 py-3.5 text-xs font-medium tracking-[0.22em] text-cream uppercase transition hover:bg-cream hover:text-espresso"
        >
          Contact Us
        </a>
        <a
          href="#gift-cards"
          class="border border-cream/70 px-8 py-3.5 text-xs font-medium tracking-[0.22em] text-cream uppercase transition hover:bg-cream hover:text-espresso"
        >
          Gift Cards
        </a>
      </div>
    </div>
  </div>
</section>
