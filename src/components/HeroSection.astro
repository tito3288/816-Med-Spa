---
import SectionBadge from "./SectionBadge.astro";

const stats = [
  { value: "15+", label: "Years Experience" },
  { value: "8K+", label: "Happy Clients" },
  { value: "30+", label: "Advanced Treatments" },
];
---

<section class="relative py-20 md:py-32 lg:py-40 bg-gradient-to-br from-lavender/20 via-warmGray to-cream">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-3">
        <SectionBadge label="Kansas City Medical Spa" class="mb-6" />
        <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-none mb-6">
          Choose Your Path to Radiance
        </h1>
        <p class="text-xl sm:text-2xl text-gray-600 mb-10 max-w-2xl leading-relaxed">
          Everyone's journey is unique. We're here to help you begin wherever you feel ready—whether
          you're looking to clear your skin, contour your body, or restore balance from within.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#quiz"
            class="bg-sage text-white px-8 py-4 text-center hover:bg-sage/90 transition font-medium"
          >
            Take Our Skin Quiz
          </a>
          <a
            href="#services"
            class="bg-white border-2 border-sage text-sage px-8 py-4 text-center hover:bg-sage hover:text-white transition font-medium"
          >
            Browse All Services
          </a>
        </div>
        <dl class="mt-12 grid grid-cols-3 gap-8">
          {stats.map((stat) => (
            <div>
              <dt class="sr-only">{stat.label}</dt>
              <dd>
                <span class="block text-4xl font-display text-sage mb-2">{stat.value}</span>
                <span class="block text-sm text-gray-600 uppercase tracking-wide">{stat.label}</span>
              </dd>
            </div>
          ))}
        </dl>
      </div>
      <div class="lg:col-span-2">
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="aspect-[3/4] bg-gray-200 rounded-lg overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600"
                alt="Calm, modern medical spa interior with soft natural light"
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
                width="600"
                height="800"
              />
            </div>
          </div>
          <div class="space-y-4 pt-8">
            <div class="aspect-square bg-gray-200 rounded-lg overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=600"
                alt="Aesthetician applying a facial treatment to a relaxed client"
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
                width="600"
                height="600"
              />
            </div>
            <div class="aspect-[3/4] bg-gray-200 rounded-lg overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?w=600"
                alt="Wellness consultation between practitioner and client"
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
                width="600"
                height="800"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
