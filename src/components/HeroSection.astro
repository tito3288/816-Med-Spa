---
---

<section class="hero relative isolate min-h-screen w-full overflow-hidden">
  <div
    class="relative z-[1] flex min-h-screen flex-col items-center justify-center px-6 pt-[200px] pb-[120px] text-center max-[900px]:pt-[160px]"
  >
    <p class="hero-eyebrow" data-reveal>Med Spa in Kansas City, Missouri</p>
    <h1 class="hero-headline" data-reveal style="--reveal-delay: 120ms">
      this must be<br />the place.
    </h1>
    <div
      class="hero-ctas flex flex-wrap justify-center gap-[22px]"
      data-reveal
      style="--reveal-delay: 320ms"
    >
      <a href="#" class="hero-btn">Schedule Now</a>
      <a href="#" class="hero-btn">Contact Us</a>
      <a href="#" class="hero-btn">Gift Cards</a>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: #8f7f68;
    background-image:
      linear-gradient(rgba(90, 76, 56, 0.35), rgba(60, 48, 33, 0.45)),
      url("https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?auto=format&fit=crop&w=1920&q=80");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-eyebrow {
    font-family: var(--font-sans-wide);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-parchment);
    opacity: 0.95;
    margin-bottom: 28px;
  }

  .hero-headline {
    font-family: var(--font-serif-italic);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(56px, 8vw, 132px);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-parchment);
    max-width: 1000px;
    margin: 0 0 56px;
  }

  .hero-btn {
    display: inline-block;
    padding: 20px 36px;
    border: 1px solid var(--color-parchment);
    color: var(--color-parchment);
    background: transparent;
    font-family: var(--font-sans-wide);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    text-align: center;
    min-width: 220px;
    transition: all 0.25s ease;
  }

  .hero-btn:hover {
    background: var(--color-parchment);
    color: var(--color-ink);
  }
</style>
