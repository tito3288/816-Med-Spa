---
import SectionBadge from "./SectionBadge.astro";
import ConditionCard from "./ConditionCard.astro";

const unsplash = (id: string) =>
  `https://images.unsplash.com/${id}?auto=format&fit=crop&w=800&h=1067&q=80`;

const conditions = [
  {
    title: "Skin Care",
    description: "Personalized facials, resurfacing, and treatments designed around your glow goals",
    href: "#skin-care",
    image: unsplash("photo-1570172619644-dfd03ed5d881"),
  },
  {
    title: "Weight Loss",
    description: "Tailored support to help you regain control, build confidence, and feel renewed",
    href: "#weight-loss",
    image: unsplash("photo-1571019613454-1cb2f99b2d8b"),
  },
  {
    title: "Hormone Therapy",
    description: "Balance, harmony, and renewal through care designed to optimize your well-being",
    href: "#hormone-therapy",
    image: unsplash("photo-1544161515-4ab6ce6db874"),
  },
  {
    title: "Botox & Fillers",
    description: "Refined face and contouring solutions for natural-looking, confidence-building results",
    href: "#botox-fillers",
    image: unsplash("photo-1487412947147-5cebf100ffc2"),
  },
  {
    title: "Morpheus8",
    description: "Advanced technology for smoother texture, tighter-looking skin, and refreshed radiance",
    href: "#morpheus8",
    image: unsplash("photo-1616394584738-fc6e612e71b9"),
  },
];
---

<section id="conditions" class="bg-cream py-20 lg:py-32">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <SectionBadge label="Beauty Beyond Boundaries" class="mb-6" />
      <h2 class="font-display mb-6 text-4xl sm:text-5xl lg:text-6xl" data-reveal>
        <span class="font-bold">Treatments</span> Tailored <span class="font-bold">to You</span>
      </h2>
      <p class="mx-auto max-w-3xl text-lg text-gray-600" data-reveal style="--reveal-delay: 120ms">
        From skin care and injectables to weight loss and hormone replacement therapy, our
        rejuvenating services are tailored to your goals. You are not just a client; you are the
        masterpiece.
      </p>
    </div>
    <div
      class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 [-ms-overflow-style:none] [scrollbar-width:thin] lg:grid lg:grid-cols-5 lg:gap-4 lg:overflow-visible lg:pb-0 lg:snap-none [&::-webkit-scrollbar]:h-1.5 [&::-webkit-scrollbar-thumb]:bg-sage/40"
    >
      {conditions.map((c, i) => (
        <div
          class="w-[min(78vw,280px)] shrink-0 snap-start lg:w-auto lg:min-w-0 lg:shrink"
          data-reveal
          style={`--reveal-delay: ${Math.min(i, 4) * 90}ms`}
        >
          <ConditionCard
            title={c.title}
            description={c.description}
            href={c.href}
            image={c.image}
          />
        </div>
      ))}
    </div>
  </div>
</section>
