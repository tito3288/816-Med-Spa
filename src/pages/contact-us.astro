---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import QuizTab from "../components/QuizTab.astro";
import SectionBadge from "../components/SectionBadge.astro";

const phoneDigits = "8165512322";
const phoneDisplay = "816-551-2322";
const addressLine1 = "638 W 39th St.";
const addressLine2 = "Kansas City, MO 64111";
const mapsHref = "https://www.google.com/maps/dir/?api=1&destination=638+W+39th+St,+Kansas+City,+MO+64111";
const mapEmbedSrc = "https://www.google.com/maps?q=638+W+39th+St,+Kansas+City,+MO+64111&output=embed";
const janeAppUrl = "https://816medspa.janeapp.com/";

const hours = [
  { day: "Monday", time: "9 AM – 4 PM" },
  { day: "Tuesday", time: "9 AM – 6 PM" },
  { day: "Wednesday", time: "Closed" },
  { day: "Thursday", time: "9 AM – 6 PM" },
  { day: "Friday", time: "9 AM – 4 PM" },
];
---

<BaseLayout
  title="Contact | 816 Med Spa Kansas City"
  description="Visit 816 Aesthetic Med Spa in Kansas City for personalized skin care, weight loss, hormone therapy, Botox, and Morpheus8 treatments at 638 W 39th St."
  canonical="https://816medspa.com/contact-us/"
>
  <SiteHeader />
  <main>
    <!-- Hero -->
    <section class="contact-hero relative isolate min-h-[84vh] w-full overflow-hidden">
      <div
        class="relative z-[1] flex min-h-[84vh] flex-col items-center justify-center px-6 pt-[200px] pb-[100px] text-center max-[900px]:pt-[160px]"
      >
        <h1
          class="mx-auto mb-9 max-w-5xl font-serif-italic text-[clamp(56px,8vw,124px)] font-light italic leading-none text-parchment"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          start with a conversation.
        </h1>
        <p
          class="mx-auto max-w-2xl text-base leading-relaxed text-parchment/90 sm:text-lg"
          data-reveal
          style="--reveal-delay: 220ms"
        >
          Schedule your visit, ask a question, or get help choosing the right next step for your skin, wellness, and aesthetic goals.
        </p>
      </div>
    </section>

    <!-- Contact details + Send a message -->
    <section class="bg-bone py-20 lg:py-28">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
          <div class="self-center">
            <SectionBadge label="Plan Your Visit" class="mb-6" />
            <h2
              class="max-w-2xl font-display text-5xl italic leading-[1.05] text-ink sm:text-6xl lg:text-7xl"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              everything you need, before you arrive.
            </h2>
            <p
              class="mt-7 max-w-xl text-base leading-relaxed text-ink/70 sm:text-lg"
              data-reveal
              style="--reveal-delay: 220ms"
            >
              Find us in Midtown Kansas City on 39th Street. Our team can help with appointment questions, service details, and the best way to begin.
            </p>
            <div
              class="mt-10 max-w-xl rounded-lg border border-sage/20 bg-cream p-6 sm:p-7"
              data-reveal
              style="--reveal-delay: 300ms"
            >
              <p class="font-dm-sans text-[11px] font-medium tracking-[0.32em] uppercase text-gold">Studio Hours</p>
              <dl class="mt-5 grid gap-3 text-sm text-ink/75">
                {hours.map((h) => (
                  <div class="grid grid-cols-[1fr_auto] items-center gap-4 border-b border-sage/15 pb-3 last:border-0 last:pb-0">
                    <dt class="font-medium text-ink">{h.day}</dt>
                    <dd>{h.time}</dd>
                  </div>
                ))}
              </dl>
            </div>

            <div
              class="mt-5 grid max-w-xl gap-5 sm:grid-cols-2"
              data-reveal
              style="--reveal-delay: 380ms"
            >
              <a
                href={mapsHref}
                target="_blank"
                rel="noopener noreferrer"
                class="group rounded-lg border border-sage/20 bg-cream p-6 transition hover:-translate-y-0.5 hover:border-sage/40"
              >
                <p class="font-dm-sans text-[11px] font-medium tracking-[0.32em] uppercase text-gold">Visit</p>
                <p class="mt-4 font-display text-2xl italic leading-tight text-ink">
                  {addressLine1}<br />{addressLine2}
                </p>
              </a>

              <a
                href={`tel:${phoneDigits}`}
                class="group rounded-lg border border-sage/20 bg-cream p-6 transition hover:-translate-y-0.5 hover:border-sage/40"
              >
                <p class="font-dm-sans text-[11px] font-medium tracking-[0.32em] uppercase text-gold">Call</p>
                <p class="mt-4 font-display text-2xl italic leading-tight text-ink">{phoneDisplay}</p>
                <p class="mt-3 text-sm leading-relaxed text-ink/60">We are happy to answer questions before you book.</p>
              </a>
            </div>
          </div>

          <div>
            <div
              class="rounded-lg border border-sage/20 bg-white p-6 shadow-sm sm:p-8"
              data-reveal
              style="--reveal-delay: 180ms"
            >
              <div class="mb-6">
                <p class="font-dm-sans text-[11px] font-medium tracking-[0.32em] uppercase text-gold">Send a Message</p>
                <h3 class="mt-3 font-display text-4xl italic leading-tight text-ink">
                  tell us what you are looking for.
                </h3>
              </div>
              <div
                data-formstack-slot
                class="overflow-hidden rounded-lg border border-sage/20 bg-white"
              >
                <iframe
                  src="https://alphadogagency.formstack.com/forms/816_med_spa"
                  title="Formstack Form"
                  width="600"
                  height="1100"
                  loading="lazy"
                  class="block min-h-[1100px] w-full border-0"
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map -->
    <section class="bg-cream py-20 lg:py-28">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p
            class="mb-6 font-dm-sans text-[12px] font-medium tracking-[0.4em] uppercase text-gold"
            data-reveal
          >
            Find Us
          </p>
          <h2
            class="font-display text-4xl italic leading-tight text-ink sm:text-5xl lg:text-6xl"
            data-reveal
            style="--reveal-delay: 120ms"
          >
            Visit our Kansas City studio.
          </h2>
          <p
            class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-ink/70"
            data-reveal
            style="--reveal-delay: 220ms"
          >
            Tucked into Midtown's 39th Street corridor — easy to find, easy to love.
          </p>
        </div>
        <div
          class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-sage/20 shadow-sm"
          data-reveal
          style="--reveal-delay: 320ms"
        >
          <div class="relative aspect-[16/9]">
            <iframe
              title="Map showing 816 Med Spa location at 638 W 39th St, Kansas City"
              src={mapEmbedSrc}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="absolute inset-0 size-full border-0"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA band -->
    <section class="bg-sage py-20 text-white lg:py-28">
      <div class="container mx-auto px-4 text-center sm:px-6 lg:px-8">
        <p
          class="mb-4 font-dm-sans text-[12px] font-medium tracking-[0.4em] uppercase text-white/80"
          data-reveal
        >
          Ready when you are
        </p>
        <h2
          class="mx-auto max-w-3xl font-display text-4xl italic leading-tight sm:text-5xl lg:text-6xl"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          Your transformation awaits.
        </h2>
        <p
          class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-white/90 sm:text-lg"
          data-reveal
          style="--reveal-delay: 220ms"
        >
          Book your consultation online or give us a call — we can't wait to meet you.
        </p>
        <div
          class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
          data-reveal
          style="--reveal-delay: 320ms"
        >
          <a
            href={`tel:${phoneDigits}`}
            class="rounded-full bg-white px-10 py-4 text-center text-lg font-medium text-sage transition hover:bg-white/90"
          >
            Call {phoneDisplay}
          </a>
          <a
            href={janeAppUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border-2 border-white px-10 py-4 text-center text-lg font-medium text-white transition hover:bg-white hover:text-sage"
          >
            Request an Appointment
          </a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <QuizTab />
</BaseLayout>

<style>
  .contact-hero {
    background-color: #8f7f68;
    background-image:
      linear-gradient(rgba(70, 58, 42, 0.34), rgba(46, 38, 29, 0.56)),
      url("https://images.unsplash.com/photo-1540555700478-4be289fbecef?auto=format&fit=crop&w=1920&q=80");
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }
</style>
