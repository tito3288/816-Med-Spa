---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import QuizTab from "../../components/QuizTab.astro";
import WhyChoose816 from "../../components/WhyChoose816.astro";
import { concerns, concernsByCategory } from "../../data/concerns";
import { concernDetails } from "../../data/concern-details";
import { processByCategory } from "../../data/process";

export function getStaticPaths() {
  return concerns.map((concern) => ({
    params: { slug: concern.slug },
    props: { concern },
  }));
}

const { concern } = Astro.props;
const janeAppUrl = "https://816medspa.janeapp.com/";

const detail = concernDetails[concern.slug];
const steps = processByCategory[concern.category] ?? [];

const related = concernsByCategory(concern.category)
  .filter((c) => c.slug !== concern.slug)
  .slice(0, 4);

// Build the alternating-background rhythm from the sections actually present.
const sectionOrder = [
  "understanding",
  ...(detail ? ["signsCauses"] : []),
  "treatments",
  ...(steps.length ? ["expect"] : []),
  "why",
  ...(detail && detail.faqs.length ? ["faq"] : []),
  ...(related.length ? ["related"] : []),
];
const bgOf = (key: string) =>
  sectionOrder.indexOf(key) % 2 === 0 ? "bg-bone" : "bg-cream";
---

<BaseLayout
  title={`${concern.name} | Concerns | 816 Med Spa`}
  description={concern.intro}
  canonical={`https://816medspa.com/concerns/${concern.slug}/`}
  ogImage={concern.image}
>
  <SiteHeader />
  <main>
    <section class="relative isolate overflow-hidden bg-espresso text-parchment">
      <div class="container mx-auto grid items-center gap-12 px-4 pt-[180px] pb-20 sm:px-6 lg:grid-cols-[1fr_0.82fr] lg:px-8 lg:pt-[230px] lg:pb-24">
        <div class="relative z-[1] max-w-3xl">
          <p
            class="mb-7 font-sans-wide text-[11px] font-normal tracking-[0.4em] uppercase text-parchment/80"
            data-reveal
          >
            {concern.category} Concern
          </p>
          <h1
            class="font-serif-italic text-[clamp(48px,7vw,104px)] font-light italic leading-[0.98] text-parchment"
            data-reveal
            style="--reveal-delay: 120ms"
          >
            {concern.name}
          </h1>
          <p
            class="mt-8 max-w-2xl text-base leading-relaxed text-parchment/85 sm:text-lg"
            data-reveal
            style="--reveal-delay: 220ms"
          >
            {concern.intro}
          </p>
        </div>

        <div
          class="relative z-[1] mx-auto w-full max-w-[480px]"
          data-reveal="fade-left"
          style="--reveal-delay: 260ms"
        >
          <div class="absolute top-4 left-4 h-full w-full rounded-lg bg-sage/50" aria-hidden="true"></div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-sage/20">
            <img
              src={concern.image}
              alt={concern.name}
              width="600"
              height="750"
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    {/* Understanding */}
    <section class={`${bgOf("understanding")} py-20 lg:py-28`}>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
          <div>
            <p
              class="mb-4 font-sans-wide text-[11px] font-medium tracking-[0.32em] uppercase text-gold"
              data-reveal
            >
              Understanding {concern.name}
            </p>
            <h2
              class="font-display text-5xl italic leading-[1.05] text-ink sm:text-6xl"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              care made for you.
            </h2>
          </div>

          <div class="space-y-6 text-base leading-relaxed text-ink/70 sm:text-lg">
            {concern.description.map((paragraph, p) => (
              <p data-reveal style={`--reveal-delay: ${180 + p * 60}ms`}>{paragraph}</p>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Signs & Causes */}
    {detail && (
      <section class={`${bgOf("signsCauses")} py-20 lg:py-28`}>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2">
            <div
              class="rounded-lg border border-sage/20 bg-white p-7 shadow-sm sm:p-9"
              data-reveal
            >
              <p class="font-sans-wide text-[11px] font-medium tracking-[0.32em] uppercase text-gold">
                Signs You May Notice
              </p>
              <h2 class="mt-4 font-display text-3xl italic leading-tight text-ink sm:text-4xl">
                how it shows up.
              </h2>
              <ul class="mt-6 space-y-3 text-base leading-relaxed text-ink/75">
                {detail.signs.map((sign) => (
                  <li class="flex items-start gap-3 border-b border-sage/15 pb-3 last:border-0 last:pb-0">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-sage" aria-hidden="true"></span>
                    <span>{sign}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div
              class="rounded-lg border border-sage/20 bg-white p-7 shadow-sm sm:p-9"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="font-sans-wide text-[11px] font-medium tracking-[0.32em] uppercase text-gold">
                What Causes It
              </p>
              <h2 class="mt-4 font-display text-3xl italic leading-tight text-ink sm:text-4xl">
                why it happens.
              </h2>
              <ul class="mt-6 space-y-3 text-base leading-relaxed text-ink/75">
                {detail.causes.map((cause) => (
                  <li class="flex items-start gap-3 border-b border-sage/15 pb-3 last:border-0 last:pb-0">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-sage" aria-hidden="true"></span>
                    <span>{cause}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* Treatments that help */}
    <section class={`${bgOf("treatments")} py-20 lg:py-28`}>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="max-w-2xl">
            <p
              class="mb-4 font-sans-wide text-[11px] font-medium tracking-[0.32em] uppercase text-gold"
              data-reveal
            >
              Treatments That Help
            </p>
            <h2
              class="font-display text-4xl italic leading-tight text-ink sm:text-5xl"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              targeted options for {concern.name.toLowerCase()}.
            </h2>
            <p
              class="mt-6 text-base leading-relaxed text-ink/70 sm:text-lg"
              data-reveal
              style="--reveal-delay: 180ms"
            >
              During your consultation, we'll recommend the right combination of these treatments for your skin, body, and goals.
            </p>
          </div>

          <ul class="mt-10 flex flex-wrap gap-3" data-reveal style="--reveal-delay: 240ms">
            {concern.treatments.map((treatment) => (
              <li class="rounded-full border border-sage/30 bg-white px-6 py-3 text-sm font-medium tracking-wide text-ink/80 shadow-sm">
                {treatment}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {/* What to expect */}
    {steps.length > 0 && (
      <section class={`${bgOf("expect")} py-20 lg:py-28`}>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-6xl">
            <div class="max-w-2xl">
              <p
                class="mb-4 font-sans-wide text-[11px] font-medium tracking-[0.32em] uppercase text-gold"
                data-reveal
              >
                What to Expect
              </p>
              <h2
                class="font-display text-4xl italic leading-tight text-ink sm:text-5xl"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                your care journey.
              </h2>
            </div>

            <div class="mt-12 grid gap-6 md:grid-cols-3">
              {steps.map((step, i) => (
                <div
                  class="rounded-lg border border-sage/20 bg-white p-7 shadow-sm sm:p-8"
                  data-reveal
                  style={`--reveal-delay: ${i * 100}ms`}
                >
                  <span class="font-serif-italic text-4xl font-light italic text-sage">
                    0{i + 1}
                  </span>
                  <h3 class="mt-3 font-display text-2xl italic leading-tight text-ink">{step.title}</h3>
                  <p class="mt-3 text-base leading-relaxed text-ink/70">{step.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {/* Why 816 */}
    <WhyChoose816 class={bgOf("why")} />

    {/* FAQ */}
    {detail && detail.faqs.length > 0 && (
      <section class={`${bgOf("faq")} py-20 lg:py-28`}>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-4xl">
            <p
              class="mb-4 font-sans-wide text-[11px] font-medium tracking-[0.32em] uppercase text-gold"
              data-reveal
            >
              Frequently Asked Questions
            </p>
            <h2
              class="font-display text-4xl italic leading-tight text-ink sm:text-5xl"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              good to know.
            </h2>

            <dl class="mt-10 divide-y divide-sage/15 border-t border-sage/15">
              {detail.faqs.map((faq, i) => (
                <div class="py-6" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
                  <dt class="font-display text-xl italic leading-snug text-ink sm:text-2xl">{faq.q}</dt>
                  <dd class="mt-3 text-base leading-relaxed text-ink/70">{faq.a}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </section>
    )}

    {/* Related */}
    {related.length > 0 && (
      <section class={`${bgOf("related")} py-20 lg:py-28`}>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-6xl">
            <p
              class="mb-4 font-sans-wide text-[11px] font-medium tracking-[0.32em] uppercase text-gold"
              data-reveal
            >
              Related {concern.category} Concerns
            </p>
            <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {related.map((item, i) => (
                <a
                  href={`/concerns/${item.slug}`}
                  class="group relative block aspect-[4/5] overflow-hidden rounded-lg shadow-sm transition hover:shadow-md"
                  data-reveal
                  style={`--reveal-delay: ${i * 80}ms`}
                >
                  <img
                    src={item.image}
                    alt={item.name}
                    class="absolute inset-0 size-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                  <div
                    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"
                    aria-hidden="true"
                  ></div>
                  <h3 class="absolute inset-x-0 bottom-0 p-5 font-display text-xl text-white not-italic md:text-2xl">
                    {item.name}
                  </h3>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="bg-sage py-20 text-white lg:py-28">
      <div class="container mx-auto px-4 text-center sm:px-6 lg:px-8">
        <p
          class="mb-4 font-sans-wide text-[12px] font-medium tracking-[0.4em] uppercase text-white/80"
          data-reveal
        >
          Schedule Your Consultation Today
        </p>
        <h2
          class="mx-auto max-w-3xl font-display text-4xl italic leading-tight sm:text-5xl lg:text-6xl"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          let's build a plan around your goals.
        </h2>
        <div class="mt-10" data-reveal style="--reveal-delay: 220ms">
          <a
            href={janeAppUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block rounded-full bg-white px-10 py-4 text-center text-lg font-medium text-sage transition hover:bg-white/90"
          >
            Request an Appointment
          </a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <QuizTab />
</BaseLayout>
